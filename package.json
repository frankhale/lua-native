{
  "name": "lua-native",
  "description": "A native Node.js module for embedding Lua in your apps",
  "author": "Frank Hale",
  "license": "MIT",
  "type": "module",
  "version": "1.1.0",
  "main": "index.js",
  "types": "index.d.ts",
  "gypfile": true,
  "keywords": [
    "lua",
    "scripting",
    "native",
    "embedding"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frankhale/lua-native.git"
  },
  "scripts": {
    "prebuildify": "prebuildify --napi --strip",
    "install": "node-gyp-build",
    "build-debug": "node-gyp rebuild --debug -- -Dskip_test=0",
    "build-release": "node-gyp rebuild --release -- -Dskip_test=1",
    "build-cmake-debug": "node cmake-build.js debug",
    "build-cmake-release": "node cmake-build.js release",
    "clean": "node-gyp clean && node -e \"for (const d of ['cmake-build-debug','cmake-build-release','cmake-build-debug-visual-studio','cmake-build-release-visual-studio']) require('node:fs').rmSync(d, {recursive: true, force: true})\"",
    "start": "vitest",
    "test": "vitest",
    "test-cpp": "node run-tests.js",
    "get-vcpkg-include": "node get_vcpkg_path.js include",
    "get-vcpkg-lib": "node get_vcpkg_path.js lib"
  },
  "files": [
    "index.js",
    "src/**/*.cpp",
    "src/**/*.h",
    "binding.gyp",
    "get_vcpkg_path.js",
    "prebuilds/**/*",
    "types.d.ts",
    "index.d.ts"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "prebuildify": "^6.0.1",
    "vitest": "^4.0.18"
  }
}
